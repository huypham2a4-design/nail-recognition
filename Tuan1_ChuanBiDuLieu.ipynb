     "# ============================================\n",
     "# TUẦN 1: THU THẬP VÀ CHUẨN BỊ DỮ LIỆU\n",
     "# Dự án: Nhận diện móng tay\n",
     "# ============================================"
    ]
   },
   {
    "cell_type": "code",
    "source": [
     "from google.colab import drive\n",
     "drive.mount('/content/drive')"
    ],
    "metadata": {
     "id": "onNuF-xWpqKN"
    },
    "execution_count": null,
    "outputs": []
   },
   {
    "cell_type": "code",
    "source": [
     "import os\n",
     "dataset_path = '/content/drive/MyDrive/DataDeeplearning/DataSet'\n",
     "\n",
     "for folder in ['Train', 'Val']:\n",
     "    path = os.path.join(dataset_path, folder)\n",
     "    if os.path.exists(path):\n",
     "        print(f\"\\n📁 {folder}:\")\n",
     "        for class_name in sorted(os.listdir(path)):\n",
     "            class_path = os.path.join(path, class_name)\n",
     "            if os.path.isdir(class_path):\n",
     "                count = len(os.listdir(class_path))\n",
     "                print(f\"   - {class_name}: {count} ảnh\")"
    ],
    "metadata": {
     "id": "igAgB2cap5f9"
    },
    "execution_count": null,
    "outputs": []
   },
   {
    "cell_type": "code",
    "source": [
     "import matplotlib.pyplot as plt\n",
     "import matplotlib.image as mpimg\n",
     "\n",
     "train_path = os.path.join(dataset_path, 'Train')\n",
     "classes = sorted([d for d in os.listdir(train_path) if os.path.isdir(os.path.join(train_path, d))])\n",
     "fig, axes = plt.subplots(1, len(classes), figsize=(15, 5))\n",
     "\n",
     "for i, class_name in enumerate(classes):\n",
     "    class_path = os.path.join(train_path, class_name)\n",
     "    img_name = os.listdir(class_path)[0]\n",
     "    img = mpimg.imread(os.path.join(class_path, img_name))\n",
     "    axes[i].imshow(img)\n",
     "    axes[i].set_title(f\"Lớp: {class_name}\")\n",
     "    axes[i].axis('off')\n",
     "\n",
     "plt.suptitle('Minh họa dữ liệu móng tay thực tế')\n",
     "plt.show()"
    ],
    "metadata": {
     "id": "jJnU2-fMp7dM"
    },
    "execution_count": null,
    "outputs": []
   },
   {
    "cell_type": "code",
    "source": [
     "total = 0\n",
     "print(\"=== BÁO CÁO THỐNG KÊ DỮ LIỆU ===\")\n",
     "for folder in ['Train', 'Val']:\n",
     "    folder_total = 0\n",
     "    path = os.path.join(dataset_path, folder)\n",
     "    for class_name in os.listdir(path):\n",
     "        c_path = os.path.join(path, class_name)\n",
     "        if os.path.isdir(c_path):\n",
     "            count = len(os.listdir(c_path))\n",
     "            folder_total += count\n",
     "    print(f\"📍 Tập {folder}: {folder_total} ảnh\")\n",
     "    total += folder_total\n",
     "print(f\"✅ Tổng cộng bộ dữ liệu: {total} ảnh\")"
    ],
    "metadata": {
     "id": "4O27Vmxup-T5"
    },
    "execution_count": null,
    "outputs": []
